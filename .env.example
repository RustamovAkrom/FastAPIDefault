# =========================================================
# 🌍 ENVIRONMENT
# =========================================================

ENV=local  # local | test | prod
DEBUG=true

APP_TITLE="FastAPI Default"
APP_NAME=fastapidefault
APP_VERSION=1.0.0
API_V1_STR=/api/v1

SECRET_KEY="CHANGE_ME_SUPER_SECRET_KEY_MIN_32_CHARS"

# =========================================================
# 🌐 NETWORK / SECURITY
# =========================================================

# Allowed hosts (IMPORTANT in production)
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# CORS (frontend domains)
CORS_ORIGINS=["http://localhost:3000"]

# =========================================================
# 🗄 DATABASE (PostgreSQL)
# =========================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_default

# SQLAlchemy pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =========================================================
# 🔐 AUTH / JWT
# =========================================================

JWT_SECRET_KEY="CHANGE_ME_JWT_SECRET"
JWT_REFRESH_SECRET_KEY="CHANGE_ME_REFRESH_SECRET"
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================
# 📊 OBSERVABILITY
# =========================================================

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_KEY=

# Sentry
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =========================================================
# ⚙️ ADMIN PANEL
# =========================================================

ADMIN_ENABLED=true
ADMIN_USER=
ADMIN_PASSWORD=
ADMIN_PATH=/admin

# =========================================================
# 📧 EMAIL (SMTP)
# =========================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="FastAPI Default"

SMTP_STARTTLS=true
SMTP_SSL=false

# =========================================================
# 🚀 CELERY (Background Tasks)
# =========================================================

CELERY_ENABLED=false

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC

# =========================================================
# 📁 FILE STORAGE
# =========================================================

STATIC_ROOT=static
STATIC_URL=/static

MEDIA_ROOT=media
MEDIA_URL=/media

MAX_UPLOAD_SIZE_MB=5

# =========================================================
# 🐳 DOCKER / RUNTIME
# =========================================================

COMPOSE_PROJECT_NAME=fastapi-default
WORKERS=2
