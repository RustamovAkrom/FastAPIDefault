###### APP CORE ######
ENV=local
APP_TITLE="FastAPI Default"
APP_NAME=fastapidefault
APP_VERSION=0.1.0
APP_DESCRIPTION="FastAPI boilerplate with Docker, PostgreSQL, Redis"
APP_V1_STR=/api/v1

APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

SECRET_KEY=your-secret-key-minimum-32-chars-change-this-in-production

###### DATABASE ######
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_default

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

###### JWT ######
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

###### ADMIN ######
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PATH=/admin

###### LOGGING ######
LOG_LEVEL=INFO
LOG_JSON=false
LOG_TO_FILE=false
LOG_PATH=

###### CORS ######
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["*"]

###### RATE LIMIT ######
RATE_LIMIT_ENABLED=false
RATE_LIMIT_STORAGE_URL=redis://redis:6379/2

###### REDIS / CELERY ######
CELERY_ENABLED=true
CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

###### OBSERVABILITY (OFF BY DEFAULT) ######
PROMETHEUS_ENABLED=true
LOKI_ENABLED=true
GRAFANA_ENABLED=true
SENTRY_ENABLED=true

###### DOCKER ######
COMPOSE_PROJECT_NAME=fastapi-default
WORKERS=2
