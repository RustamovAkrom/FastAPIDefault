#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset
set -x

echo "Applying database migrations..."

alembic -c src/alembic.ini upgrade head

echo "Starting FastAPI server..."

# Get environment and determine workers
ENV=${ENV:-dev}
WORKERS=${WORKERS:-2}

# Use 4 workers in production for better concurrency
if [ "$ENV" = "prod" ]; then
  WORKERS=${WORKERS:-4}
fi

exec uvicorn app:create_app \
  --factory \
  --proxy-headers \
  --workers $WORKERS \
  --loop uvloop \
  --http httptools \
  --host 0.0.0.0 \
  --port 8000
